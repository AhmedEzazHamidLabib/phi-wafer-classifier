        "Edge-Ring": 0.9801,
        "Loc":       0.7845,
        "Near-full": 0.9531,
        "Random":    0.8165,
        "Scratch":   0.6611,
        "macro":     0.8675
      },
      "notes": "Augmentation alone adds 2.4 macro points over baseline. Near-full recovers completely. Scratch improves substantially."
    },

    "phi_no_aug_seeded": {
      "description": "Seeded phi v4 no augmentation — isolates phi contribution",
      "config": {
        "seed": 42,
        "alpha_max": 3.0, "beta_min": 0.3,
        "vel_scale": 5.0, "phi_ema": 0.8,
        "phi_init": "baseline_f1",
        "augmentation": false,
        "epochs": 20
      },
      "f1": {
        "Center":    0.9494,
        "Donut":     0.8622,
        "Edge-Loc":  0.8664,
        "Edge-Ring": 0.9789,
        "Loc":       0.7835,
        "Near-full": 0.8000,
        "Random":    0.8876,
        "Scratch":   0.6238,
        "macro":     0.8440
      },
      "notes": "Phi alone adds 0.05 macro points. Marginal without augmentation. Proves phi and augmentation solve different constraint types."
    },

    "phi_final_seeded": {
      "description": "Seeded phi v4 with augmentation — primary result",
      "config": {
        "seed": 42,
        "alpha_max": 3.0, "beta_min": 0.3,
        "vel_scale": 5.0, "phi_ema": 0.8,
